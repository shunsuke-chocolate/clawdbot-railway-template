+      parsed: params.parsed,
+      fallbackAction,
+    });
+    const message = yoakariReviewResponseText(value.action, value.episodeId);
+    await dispatchYoakariReviewAction({ parsed: params.parsed, value, message });
+    params.ctx.runtime.log?.(
+      `slack:interaction yoakari review dispatched action=${value.action} episode=${value.episodeId} user=${params.parsed.userId} channel=${params.parsed.channelId ?? "unknown"}`,
+    );
+    await respondEphemeral(params.respond, `${message} GitHub Actionsへ通知しました。`);
+  } catch (error) {
+    params.ctx.runtime.log?.(
+      `slack:interaction yoakari review dispatch failed action=${params.parsed.actionId}: ${String(error)}`,
+    );
+    await respondEphemeral(
+      params.respond,
+      `YOAKARIレビュー操作の処理に失敗しました: ${String(error)}`,
+    );
+  }
+
+  return true;
+}
