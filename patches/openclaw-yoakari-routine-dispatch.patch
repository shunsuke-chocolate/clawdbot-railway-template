+function parseYoakariRoutineActionValue(params: {
+  parsed: ParsedSlackBlockAction;
+  fallbackAction: YoakariRoutineAction;
+}): {
+  action: YoakariRoutineAction;
+  branch?: string;
+  sha?: string;
+  mode?: string;
+  note?: string;
+} {
+  const rawValue = normalizeOptionalString(params.parsed.actionSummary.value);
+  let parsedValue: Record<string, unknown> = {};
+  if (rawValue) {
+    try {
+      parsedValue = JSON.parse(rawValue) as Record<string, unknown>;
+    } catch {
+      const [action, sha, branch, mode] = rawValue.split("|");
+      parsedValue = { action, sha, branch, mode };
+    }
+  }
+
+  const action = normalizeOptionalString(parsedValue.action) ?? params.fallbackAction;
+  if (!["plan", "create", "revision"].includes(action)) {
+    throw new Error(`Invalid YOAKARI routine action: ${action}`);
+  }
+
+  return {
+    action: action as YoakariRoutineAction,
+    branch: normalizeOptionalString(parsedValue.branch) ?? undefined,
+    sha: normalizeOptionalString(parsedValue.sha) ?? undefined,
+    mode: normalizeOptionalString(parsedValue.mode) ?? undefined,
+    note: normalizeOptionalString(parsedValue.note) ?? undefined,
+  };
