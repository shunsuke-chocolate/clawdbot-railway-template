+}): Promise<void> {
+  const token = resolveYoakariGithubToken();
+  if (!token) {
+    throw new Error(
+      "YOAKARI_GITHUB_TOKEN, YOAKARI_ROUTINE_DISPATCH_TOKEN, APPROVAL_DISPATCH_TOKEN, or GITHUB_TOKEN is required.",
+    );
+  }
+
+  const owner = process.env.YOAKARI_GITHUB_REPO_OWNER?.trim() || "shunsuke-chocolate";
+  const repo = process.env.YOAKARI_GITHUB_REPO_NAME?.trim() || "yoakari-content";
+  const eventType = process.env.YOAKARI_ROUTINE_DISPATCH_EVENT?.trim() || "yoakari-routine-feedback";
+  const branch = params.value.branch || process.env.YOAKARI_GITHUB_BRANCH?.trim() || "main";
+
+  const response = await fetch(`https://api.github.com/repos/${owner}/${repo}/dispatches`, {
+    method: "POST",
+    headers: {
+      accept: "application/vnd.github+json",
+      authorization: `Bearer ${token}`,
+      "content-type": "application/json",
+      "user-agent": "openclaw-yoakari-routine-dispatch",
+      "x-github-api-version": "2022-11-28",
+    },
+    body: JSON.stringify({
+      event_type: eventType,
+      client_payload: {
+        action: params.value.action,
+        sha: params.value.sha ?? null,
+        reviewer: params.parsed.userId || "unknown",
+        note: params.value.note ?? null,
+        slack_channel: params.parsed.channelId ?? null,
+        slack_message_ts: params.parsed.messageTs ?? null,
+        slack_user_id: params.parsed.userId ?? null,
+        branch,
+        mode: params.value.mode ?? null,
+        source: "openclaw_slack_interaction",
+      },
+    }),
+  });
+
+  if (!response.ok) {
+    const detail = await response.text().catch(() => "");
+    throw new Error(
+      `GitHub repository_dispatch failed: ${response.status} ${response.statusText}${
+        detail ? ` ${detail.slice(0, 240)}` : ""
+      }`,
+    );
