+function parseYoakariReviewActionValue(params: {
+  parsed: ParsedSlackBlockAction;
+  fallbackAction: YoakariReviewAction;
+}): {
+  action: YoakariReviewAction;
+  episodeId: string;
+  branch?: string;
+  sha?: string;
+  note?: string;
+} {
+  const rawValue = normalizeOptionalString(params.parsed.actionSummary.value);
+  let parsedValue: Record<string, unknown> = {};
+  if (rawValue) {
+    try {
+      parsedValue = JSON.parse(rawValue) as Record<string, unknown>;
+    } catch {
+      const [action, episodeId, sha, branch] = rawValue.split("|");
+      parsedValue = { action, episode_id: episodeId, sha, branch };
+    }
+  }
+
+  const action = normalizeOptionalString(parsedValue.action) ?? params.fallbackAction;
+  if (
+    ![
+      "approve",
+      "changes",
+      "image_changes",
+      "image_skip",
+      "approve_image",
+      "replace",
+      "reset",
+    ].includes(action)
+  ) {
+    throw new Error(`Invalid YOAKARI review action: ${action}`);
+  }
+
+  const episodeId =
+    normalizeOptionalString(parsedValue.episode_id) ??
+    normalizeOptionalString(parsedValue.episodeId) ??
+    "";
+  if (!/^YK-(?:EP|DES)-[0-9]{4}$/.test(episodeId)) {
+    throw new Error(`Invalid YOAKARI episode_id: ${episodeId}`);
+  }
+
+  return {
+    action: action as YoakariReviewAction,
+    episodeId,
+    branch: normalizeOptionalString(parsedValue.branch) ?? undefined,
+    sha: normalizeOptionalString(parsedValue.sha) ?? undefined,
+    note: normalizeOptionalString(parsedValue.note) ?? undefined,
+  };
+}
+
+function yoakariRoutineResponseText(action: YoakariRoutineAction): string {
+  if (action === "plan") {
+    return "計画調整Issueの作成を受け付けました。具体的な指示はこのSlackスレッドの返信として扱います。";
+  }
+  if (action === "create") {
+    return "次のdraft作成Issueの作成を受け付けました。slotやepisode指定があればこのSlackスレッドの返信として扱います。";
+  }
+  return "修正Issueの作成を受け付けました。episode_idや修正内容はこのSlackスレッドの返信として扱います。";
+}
+
+function yoakariReviewResponseText(action: YoakariReviewAction, episodeId: string): string {
+  if (action === "changes") {
+    return `修正依頼として受け付けました。episode_id: ${episodeId} / 具体的な修正内容はこのSlackスレッドに返信してください。`;
+  }
+  if (action === "image_changes") {
+    return `画像差し戻しとして受け付けました。episode_id: ${episodeId} / 画像への指示はこのSlackスレッドに返信してください。`;
+  }
+  if (action === "image_skip") {
+    return `画像なし運用として受け付けました。episode_id: ${episodeId}`;
+  }
+  if (action === "replace") {
+    return `差し替え予定として受け付けました。episode_id: ${episodeId}`;
+  }
+  if (action === "reset") {
+    return `レビュー状態のリセットを受け付けました。episode_id: ${episodeId}`;
+  }
+  if (action === "approve_image") {
+    return `画像承認を受け付けました。episode_id: ${episodeId}`;
+  }
+  return `承認を受け付けました。episode_id: ${episodeId}`;
+}
