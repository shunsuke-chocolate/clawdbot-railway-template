+async function handleYoakariRoutineBlockAction(params: {
+  ctx: SlackMonitorContext;
+  parsed: ParsedSlackBlockAction;
+  respond?: SlackBlockActionRespond;
+}): Promise<boolean> {
+  const fallbackAction = parseYoakariRoutineActionId(params.parsed.actionId);
+  if (!fallbackAction) {
+    return false;
+  }
+
+  try {
+    const value = parseYoakariRoutineActionValue({
+      parsed: params.parsed,
+      fallbackAction,
+    });
+    await dispatchYoakariRoutineFeedback({ parsed: params.parsed, value });
+    const message = yoakariRoutineResponseText(value.action);
+    params.ctx.runtime.log?.(
+      `slack:interaction yoakari routine dispatched action=${value.action} user=${params.parsed.userId} channel=${params.parsed.channelId ?? "unknown"}`,
+    );
+    await respondEphemeral(params.respond, `${message} GitHub Actionsへ通知しました。`);
+  } catch (error) {
+    params.ctx.runtime.log?.(
+      `slack:interaction yoakari routine dispatch failed action=${params.parsed.actionId}: ${String(error)}`,
+    );
+    await respondEphemeral(
+      params.respond,
+      `YOAKARI Routineボタンの処理に失敗しました: ${String(error)}`,
+    );
+  }
+
+  return true;
+}
