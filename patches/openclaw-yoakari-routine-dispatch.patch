+  }
+  if (action === "create") {
+    return "次のdraft作成Issueの作成を受け付けました。slotやepisode指定があればこのSlackスレッドの返信として扱います。";
+  }
+  return "修正Issueの作成を受け付けました。episode_idや修正内容はこのSlackスレッドの返信として扱います。";
+}
